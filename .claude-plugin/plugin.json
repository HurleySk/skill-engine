{
  "name": "skill-engine",
  "version": "3.1.0",
  "description": "Rule-based skill activation and guardrail enforcement for Claude Code. Uses a persistent HTTP server for near-zero latency on every tool call.",
  "author": {
    "name": "Samuel Hurley",
    "url": "https://github.com/HurleySk"
  },
  "license": "MIT",
  "homepage": "https://github.com/HurleySk/skill-engine",
  "repository": "https://github.com/HurleySk/skill-engine",
  "keywords": [
    "skills",
    "rules",
    "enforcement",
    "learn",
    "scaffold",
    "claude-code"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/start-server.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19750/activate"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19750/enforce"
          }
        ]
      }
    ]
  }
}
