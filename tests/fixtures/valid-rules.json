{
  "version": "1.0",
  "defaults": {
    "enforcement": "suggest",
    "priority": "medium"
  },
  "rules": {
    "sql-standards": {
      "type": "guardrail",
      "enforcement": "block",
      "priority": "critical",
      "description": "Enforce SQL coding standards",
      "skillPath": "./sql-standards/SKILL.md",
      "triggers": {
        "prompt": {
          "keywords": ["stored proc", "sproc", "procedure"],
          "intentPatterns": ["(create|modify).*?proc"]
        },
        "file": {
          "pathPatterns": ["**/*.sql"],
          "pathExclusions": ["**/migrations/**"],
          "contentPatterns": ["CREATE\\s+PROC"]
        }
      },
      "blockMessage": "SQL standards apply. Read .claude/skills/sql-standards/SKILL.md first.",
      "skipConditions": {
        "envVars": ["SKIP_SQL_STANDARDS"],
        "sessionOnce": false
      }
    },
    "pipeline-guidance": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "ADF pipeline development guidance",
      "skillPath": "./adf-pipeline/SKILL.md",
      "triggers": {
        "prompt": {
          "keywords": ["pipeline", "ADF", "data factory"],
          "intentPatterns": ["(debug|fix|create).*?pipeline"]
        }
      },
      "skipConditions": {
        "sessionOnce": true
      }
    },
    "config-warning": {
      "type": "guardrail",
      "enforcement": "warn",
      "priority": "medium",
      "description": "Check config file changes carefully",
      "skillPath": "./config-safety/SKILL.md",
      "triggers": {
        "file": {
          "pathPatterns": ["**/*.config", "**/appsettings*.json"]
        }
      },
      "skipConditions": {
        "envVars": ["SKIP_CONFIG_WARN"]
      }
    },
    "no-force-push": {
      "type": "guardrail",
      "enforcement": "block",
      "priority": "high",
      "description": "Force push is not allowed",
      "blockMessage": "Blocked: force push detected. Use regular push instead.",
      "triggers": {
        "tool": {
          "toolNames": ["Bash", "PowerShell"],
          "inputPatterns": ["push\\s+(--force|-f)"]
        }
      }
    },
    "test-after-edit": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "description": "Run tests after editing TypeScript files",
      "guidance": "You just edited a TypeScript file. Run `npm test` to verify your changes.",
      "triggers": {
        "output": {
          "toolNames": ["Edit", "Write"],
          "outputPatterns": ["\\.ts"]
        }
      }
    },
    "commit-reminder": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "low",
      "description": "Remember to commit your changes",
      "guidance": "Consider committing your changes before ending this session.",
      "hookEvents": ["Stop"],
      "triggers": {},
      "skipConditions": {
        "sessionOnce": true
      }
    }
  }
}
