{
  "permissions": {
    "allow": ["Read", "Glob", "Grep"]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill-engine/activate.sh\""
      }
    ],
    "PreToolUse": [
      {
        "matcher": ["Edit", "Write", "MultiEdit"],
        "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill-engine/enforce.sh\""
      }
    ]
  }
}
